<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Món Ăn Yêu Thích"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#029207"
            android:gravity="center"
            android:layout_marginBottom="20dp"/>

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <!-- Sản phẩm 1 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@android:color/white"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:id="@+id/img_food1"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/pizza_hai_san" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pizza Hải Sản"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:textColor="#333333"/>

                <Button
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đặt hàng"
                    android:backgroundTint="#029207"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Sản phẩm 2 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@android:color/white"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/hamburger_bo" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Hamburger Bò"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:textColor="#333333"/>

                <Button
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đặt hàng"
                    android:backgroundTint="#029207"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"
                    android:textSize="12sp"/>
            </LinearLayout>

            <!-- Sản phẩm 3 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="8dp"
                android:background="@android:color/white"
                android:elevation="4dp"
                android:orientation="vertical"
                android:padding="8dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ga_ran_kfc" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Gà Rán KFC"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp"
                    android:textColor="#333333"/>

                <Button
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đặt hàng"
                    android:backgroundTint="#029207"
                    android:textColor="#FFFFFF"
                    android:layout_marginTop="8dp"
                    android:textSize="12sp"/>
            </LinearLayout>

        </GridLayout>
    </LinearLayout>
</ScrollView>